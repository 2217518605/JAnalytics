    product_name: str = "高腰显瘦牛仔裤"
    style: str = "直筒"
    scene: str = "抖音短视频"
    target_audience: str = "年轻女性"
    key_selling_points: str = "显瘦、高腰、百搭"
    tone: str = "亲和"
